APP_NAME=Alice Home OS API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
TIMEZONE=Europe/London
DATABASE_URL=sqlite:///./data/alice.db
JWT_SECRET=dev-only-secret-change-me-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=720
MQTT_ENABLED=false
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=alice-hub-api
MQTT_TOPIC_PREFIX=alice/v1
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILENAME=hub-api.log
LOG_JSON_FILENAME=hub-api.jsonl
LOG_HTTP_REQUEST_BODIES=false
LOG_HTTP_REQUEST_BODY_MAX_BYTES=4096
LOG_HTTP_INCLUDE_DOCS_REQUESTS=false
AUTO_LIGHT_ENABLED=false
AUTO_LIGHT_SENSOR_ENTITY_ID=
AUTO_LIGHT_TARGET_ENTITY_ID=
AUTO_LIGHT_MODE=lux_low_turn_on
AUTO_LIGHT_ON_LUX=120
AUTO_LIGHT_OFF_LUX=220
AUTO_LIGHT_ON_RAW=3000
AUTO_LIGHT_OFF_RAW=2600
AUTO_LIGHT_BLOCK_ON_DURING_DAYTIME=true
AUTO_LIGHT_DAYTIME_START_HOUR=7
AUTO_LIGHT_DAYTIME_END_HOUR=18
AUTO_LIGHT_ACTOR_ID=system:auto-light
DEVICE_OFFLINE_TIMEOUT_SECONDS=45
DEFAULT_ADMIN_EMAIL=admin@alice.systems
DEFAULT_ADMIN_PASSWORD=change-me
DEFAULT_ADMIN_DISPLAY_NAME=Alice Admin
ENABLE_DOCS=true
