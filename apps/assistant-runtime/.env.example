APP_NAME=Alice Assistant Runtime
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=*
ASSISTANT_MODE=deterministic
ASSISTANT_ALLOW_FALLBACK=true
SESSION_STORE_FILE=./data/assistant.db
SESSION_HISTORY_WINDOW=8
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_SECONDS=20
HOME_OS_BASE_URL=http://127.0.0.1:8000/api/v1
HOME_OS_EMAIL=
HOME_OS_PASSWORD=
HOME_OS_ENV_FALLBACK_FILE=../hub-api/.env
